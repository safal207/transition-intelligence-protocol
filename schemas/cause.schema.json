{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cause.schema.json",
  "title": "Cause",
  "type": "object",
  "required": ["cause_id", "cause_type", "summary", "supporting_signals", "basis"],
  "properties": {
    "cause_id": {
      "type": "string"
    },
    "cause_type": {
      "type": "string",
      "enum": [
        "intent",
        "constraint",
        "conflict",
        "opportunity",
        "risk",
        "permission"
      ]
    },
    "summary": {
      "type": "string"
    },
    "supporting_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "basis": {
      "type": "string"
    },
    "parent_cause": {
      "type": ["string", "null"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
